{
  "workspace": [
    "./packages/core",
    "./packages/shared",
    "./packages/store-memory",
    "./packages/store-pg",
    "./packages/store-sqlite"
  ],
  "tasks": {
    "test": "deno test --allow-all --parallel",
    "test:core": "deno test --allow-all packages/core/",
    "test:memory": "deno test --allow-all packages/store-memory/",
    "test:pg": "deno test --allow-all packages/store-pg/",
    "test:sqlite": "deno test --allow-all packages/store-sqlite/",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check packages/*/src/mod.ts"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  }
}
