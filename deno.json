{
  "nodeModulesDir": "auto",
  "workspace": [
    "./packages/core",
    "./packages/shared",
    "./packages/store-memory",
    "./packages/store-pg",
    "./packages/store-sqlite-core",
    "./packages/store-sqlite-node",
    "./packages/store-sqlite-bun",
    "./packages/store-sqlite-deno"
  ],
  "imports": {
    "@conveyor/core": "./packages/core/src/mod.ts",
    "@conveyor/shared": "./packages/shared/src/mod.ts",
    "@conveyor/store-memory": "./packages/store-memory/src/mod.ts",
    "@conveyor/store-pg": "./packages/store-pg/src/mod.ts",
    "@conveyor/store-sqlite-core": "./packages/store-sqlite-core/src/mod.ts",
    "@conveyor/store-sqlite-node": "./packages/store-sqlite-node/src/mod.ts",
    "@conveyor/store-sqlite-bun": "./packages/store-sqlite-bun/src/mod.ts",
    "@conveyor/store-sqlite-deno": "./packages/store-sqlite-deno/src/mod.ts",
    "@db/sqlite": "jsr:@db/sqlite@^0.13",
    "vitest": "npm:vitest@^3"
  },
  "tasks": {
    "test": "deno -A npm:vitest run",
    "test:deno": "deno -A npm:vitest run",
    "test:core": "deno -A npm:vitest run tests/core/ tests/conformance/",
    "test:memory": "deno -A npm:vitest run tests/conformance/",
    "test:pg": "deno -A npm:vitest run tests/store-pg/",
    "test:sqlite:node": "deno -A npm:vitest run --config vitest.sqlite.config.ts tests/store-sqlite-node/",
    "test:sqlite:bun": "bun test tests/store-sqlite-bun/",
    "test:sqlite:deno": "deno -A npm:vitest run --config vitest.sqlite.config.ts tests/store-sqlite-deno/",
    "bench": "deno bench --allow-env --allow-read --allow-write benchmarks/",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check packages/*/src/mod.ts"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    },
    "exclude": ["tests/bun-vitest-shim.ts", "bunfig.toml"]
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  }
}
