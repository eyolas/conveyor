{
  "nodeModulesDir": "auto",
  "workspace": [
    "./packages/core",
    "./packages/shared",
    "./packages/store-memory",
    "./packages/store-pg",
    "./packages/store-sqlite-core",
    "./packages/store-sqlite-node",
    "./packages/store-sqlite-bun",
    "./packages/store-sqlite-deno",
    "./packages/dashboard-api",
    "./packages/dashboard",
    "./packages/dashboard-client",
    "./packages/store-redis"
  ],
  "imports": {
    "@conveyor/dashboard": "./packages/dashboard/src/mod.ts",
    "@conveyor/dashboard-client": "./packages/dashboard-client/src/mod.ts",
    "@conveyor/dashboard-api": "./packages/dashboard-api/src/mod.ts",
    "@conveyor/core": "./packages/core/src/mod.ts",
    "@conveyor/shared": "./packages/shared/src/mod.ts",
    "@conveyor/store-memory": "./packages/store-memory/src/mod.ts",
    "@conveyor/store-pg": "./packages/store-pg/src/mod.ts",
    "@conveyor/store-sqlite-core": "./packages/store-sqlite-core/src/mod.ts",
    "@conveyor/store-sqlite-node": "./packages/store-sqlite-node/src/mod.ts",
    "@conveyor/store-sqlite-bun": "./packages/store-sqlite-bun/src/mod.ts",
    "@conveyor/store-sqlite-deno": "./packages/store-sqlite-deno/src/mod.ts",
    "@conveyor/store-redis": "./packages/store-redis/src/mod.ts",
    "@db/sqlite": "jsr:@db/sqlite@^0.13",
    "redis": "npm:redis@^5.12.1",
    "vitest": "npm:vitest@^4"
  },
  "tasks": {
    "test": "deno -A npm:vitest run",
    "test:deno": "deno -A npm:vitest run",
    "test:core": "deno -A npm:vitest run tests/core/ tests/conformance/",
    "test:memory": "deno -A npm:vitest run tests/conformance/",
    "test:pg": "deno -A npm:vitest run tests/store-pg/",
    "test:sqlite:node": "deno -A npm:vitest run --config vitest.sqlite.config.ts tests/store-sqlite-node/",
    "test:sqlite:bun": "bun test tests/store-sqlite-bun/",
    "test:sqlite:deno": "deno -A npm:vitest run --config vitest.sqlite.config.ts tests/store-sqlite-deno/",
    "test:dashboard-api": "deno -A npm:vitest run --config vitest.dashboard-api.config.ts tests/dashboard-api/",
    "test:dashboard-client": "deno -A npm:vitest run --config vitest.dashboard-client.config.ts tests/dashboard-client/",
    "test:redis": "deno -A npm:vitest run tests/store-redis/",
    "bench": "deno bench --allow-env --allow-read --allow-write benchmarks/",
    "bench:report": "deno run --allow-run --allow-write --allow-read --allow-env benchmarks/generate-report.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check packages/*/src/mod.ts",
    "setup": "git config core.hooksPath .githooks",
    "build:ui": "cd packages/dashboard/ui && npx vite build",
    "dev:ui": "cd packages/dashboard/ui && npx vite",
    "dev:api": "deno run --allow-all --watch examples/with-dashboard/main.ts",
    "dev:readonly": "deno run --allow-all --watch examples/dashboard-readonly-smoke.ts",
    "dev:dashboard": "deno run --allow-all --watch examples/with-dashboard/main.ts & cd packages/dashboard/ui && npx vite",
    "docs:dev": "cd docs && npx vitepress dev",
    "docs:build": "cd docs && npx vitepress build",
    "docs:preview": "cd docs && npx vitepress preview"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true,
    "exclude": ["docs/", "packages/dashboard/ui/", "packages/dashboard/dist/"]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    },
    "exclude": [
      "tests/bun-vitest-shim.ts",
      "bunfig.toml",
      "docs/",
      "packages/dashboard/ui/",
      "packages/dashboard/dist/"
    ]
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  }
}
