{
  "nodeModulesDir": "auto",
  "workspace": [
    "./packages/core",
    "./packages/shared",
    "./packages/store-memory",
    "./packages/store-pg",
    "./packages/store-sqlite"
  ],
  "imports": {
    "@conveyor/core": "./packages/core/src/mod.ts",
    "@conveyor/shared": "./packages/shared/src/mod.ts",
    "@conveyor/store-memory": "./packages/store-memory/src/mod.ts",
    "@conveyor/store-pg": "./packages/store-pg/src/mod.ts",
    "@conveyor/store-sqlite": "./packages/store-sqlite/src/mod.ts",
    "@std/assert": "jsr:@std/assert@^1.0.0"
  },
  "tasks": {
    "test": "deno test --allow-env --allow-read --allow-write --allow-net --parallel",
    "test:core": "deno test --allow-env --allow-read --allow-write tests/core/ tests/conformance/",
    "test:memory": "deno test --allow-env --allow-read --allow-write tests/conformance/",
    "test:pg": "deno test --allow-env --allow-read --allow-write --allow-net tests/store-pg/",
    "test:sqlite": "deno test --allow-env --allow-read --allow-write tests/store-sqlite/",
    "test:coverage": "deno test --allow-env --allow-read --allow-write --allow-net --parallel --coverage=coverage/ && deno coverage coverage/",
    "bench": "deno bench --allow-env --allow-read --allow-write benchmarks/",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check packages/*/src/mod.ts"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  }
}
